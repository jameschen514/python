<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <handlers>
            <add name="PybugsIIS" path="*" verb="*" modules="FastCgiModule" scriptProcessor="C:\Python\Python3\python.exe|C:\inetpub\wwwroot\pybugs\wfastcgi.py" resourceType="Unspecified" />
        </handlers>
    </system.webServer>
</configuration>
